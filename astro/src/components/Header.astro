---
import ThemeToggle from "./ThemeToggle.astro";
import { navigation, site } from "../data/site";

const currentPath = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? currentPath === "/" : currentPath.startsWith(href));
const hasActiveChild = (item: (typeof navigation)[number]) => item.children?.some((child) => isActive(child.href));
---

<header class="site-header" data-header>
	<a class="brand-mark" href="/" aria-label={`${site.name} - accueil`}>
		<img src="/LogoUID.png" alt="" width="104" height="60" />
	</a>

	<nav class="desktop-nav" aria-label="Navigation principale">
		{
			navigation.map((item) => (
				<div class:list={["nav-cluster", { "is-active": isActive(item.href) || hasActiveChild(item) }]}>
					<a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
						{item.label}
					</a>
					{item.children && (
						<div class="nav-submenu" aria-label={`${item.label} - sous-menu`}>
							{item.children.map((child) => (
								<a href={child.href} aria-current={isActive(child.href) ? "page" : undefined}>
									{child.label}
								</a>
							))}
						</div>
					)}
				</div>
			))
		}
	</nav>

	<ThemeToggle />

	<button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-toggle>
		<span class="sr-only">Ouvrir le menu</span>
		<span aria-hidden="true"></span>
		<span aria-hidden="true"></span>
	</button>
</header>

<div class="menu-panel" id="site-menu" data-menu-panel aria-hidden="true">
	<div class="menu-panel__inner">
		<p class="menu-panel__label">Union Instrumentale Delémont</p>
		<nav aria-label="Navigation mobile">
			{
				navigation.map((item) => (
					<div class="menu-panel__group">
						<a href={item.href} data-menu-link aria-current={isActive(item.href) ? "page" : undefined}>
							{item.label}
						</a>
						{item.children && (
							<div class="menu-panel__subnav">
								{item.children.map((child) => (
									<a href={child.href} data-menu-link aria-current={isActive(child.href) ? "page" : undefined}>
										{child.label}
									</a>
								))}
							</div>
						)}
					</div>
				))
			}
		</nav>
		<ThemeToggle className="menu-panel__theme" showLabel />
	</div>
</div>
