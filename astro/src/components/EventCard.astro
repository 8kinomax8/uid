---
import type { EventItem } from "../data/site";

type Props = {
	event: EventItem;
	index?: number;
};

const { event, index = 0 } = Astro.props;
---

<article class="event-card" style={`--delay:${index * 0.08}s`}>
	<a href={event.href} class="event-card__media" aria-label={`En savoir plus sur ${event.title}`}>
		<img src={event.image} alt="" width="900" height="760" loading={index === 0 ? "eager" : "lazy"} decoding="async" />
	</a>
	<div class="event-card__content">
		<div class="event-card__meta">
			<span>{event.date}</span>
			<span>{event.location}</span>
		</div>
		<h3>{event.title}</h3>
		<p>{event.summary}</p>
		<a class="text-link" href={event.href}>
			En savoir plus
			<span aria-hidden="true"> →</span>
		</a>
	</div>
</article>
